# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Source systems ────────────────────────────────────────────────────────────
DANISH_DEMOCRACY_BASE_URL="https://oda.ft.dk/api"

# ── Dagster ───────────────────────────────────────────────────────────────────
# Path to the .dagster/ directory at the repo root.
# Override in Docker/CI to point to a persistent volume.
DAGSTER_HOME="/path/to/repo/.dagster"

# ── dbt ───────────────────────────────────────────────────────────────────────
DBT_FRESHNESS_WARN_AFTER_DAYS=2
DBT_FRESHNESS_ERROR_AFTER_DAYS=7
DBT_PROJECT_DIRECTORY="/path/to/repo/dbt"
DBT_MODELS_DIRECTORY="/path/to/repo/dbt/models"
DBT_LOGS_DIRECTORY="/path/to/repo/dbt/logs"
DBT_LOGS_DIRECTORY_FABRIC="<YOUR_LAKEHOUSE>.Lakehouse/Files/DataEngineering/Logs/dbt"

# ── dlt ───────────────────────────────────────────────────────────────────────
DLT_PIPELINES_DIR="/path/to/repo/dlt/pipelines_dir"
DLT_PIPELINE_RUN_LOG_DIR="<YOUR_LAKEHOUSE>.Lakehouse/Files/DataEngineering/Logs"

# ── DuckDB ────────────────────────────────────────────────────────────────────
DUCKDB_DATABASE_LOCATION="/path/to/repo/duckdb/danish_democracy_data.duckdb"
DUCKDB_DATABASE=danish_democracy_data

# ── Azure AD service principal ────────────────────────────────────────────────
# Required for OneLake access and Fabric capacity management.
AZURE_TENANT_ID=<your-azure-tenant-id>
AZURE_SUBSCRIPTION_ID=<your-azure-subscription-id>
AZURE_RESOURCE_GROUP="<your-resource-group>"
AZURE_CLIENT_ID=<your-app-client-id>
AZURE_CLIENT_SECRET=<your-app-client-secret>

# ── Microsoft Fabric / OneLake ────────────────────────────────────────────────
FABRIC_CAPACITY_NAME="<your-fabric-capacity-name>"
FABRIC_WORKSPACE=<your-fabric-workspace-name>
FABRIC_ONELAKE_STORAGE_ACCOUNT=onelake
FABRIC_ONELAKE_MOUNT="/path/to/onelake/mount"
FABRIC_ONELAKE_FOLDER_BRONZE=<Workspace>.Lakehouse/Files/Bronze
FABRIC_ONELAKE_FOLDER_SILVER=<Workspace>.Lakehouse/Files/Silver
FABRIC_ONELAKE_FOLDER_GOLD=<Workspace>.Lakehouse/Files/Gold
